<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.8.xsd">

    <changeSet id="003-create-feature-group-overrides-table" author="nagasatish">
        <createTable tableName="feature_group_overrides" remarks="Group-level feature flag overrides">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true"/>
            </column>
            <column name="feature_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="group_id" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>
            <column name="enabled" type="BOOLEAN">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"/>
            <column name="updated_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"/>
        </createTable>

        <addUniqueConstraint tableName="feature_group_overrides" columnNames="feature_id,group_id" constraintName="uk_feature_group"/>

        <createIndex tableName="feature_group_overrides" indexName="idx_group_override">
            <column name="feature_id"/>
            <column name="group_id"/>
        </createIndex>

        <addForeignKeyConstraint baseTableName="feature_group_overrides" baseColumnNames="feature_id"
                                 referencedTableName="feature_flags" referencedColumnNames="id"
                                 constraintName="fk_group_override_feature" onDelete="CASCADE"/>
    </changeSet>

</databaseChangeLog>
